{
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "jaeger"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "traceID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Waterfall",
                    "url": "/explore?schemaVersion=1&panes={\"_\":{\"datasource\":\"jaeger\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceql\",\"query\":\"${__value.raw}\",\"datasource\":{\"type\":\"tempo\",\"uid\":\"jaeger\"}}]}}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "jaeger"
          },
          "limit": 20,
          "query": "{resource.service.name=\"customer-support-agent\"}",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Recent Traces \u2014 click Trace ID for waterfall",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "nested": true
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(agent_intent_classified_total[5m])) by (intent)",
          "legendFormat": "{{intent}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Request Rate by Intent",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_invocation_duration_milliseconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "P95 Latency per Agent",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_tool_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_tool_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Tool Call Duration (p50/p95)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[5m])) by (agent_name)",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Tool Calls by Agent",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "tags": [
    "agents",
    "sre"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "Developer / SRE",
  "uid": "developer-sre"
}