{
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(increase(agent_intent_classified_total[5m])) by (intent)",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ],
      "title": "Volume by Intent",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "(sum(rate(agent_cost_usd_total[5m])) by (intent) / 1000000) / sum(rate(agent_intent_classified_total[5m])) by (intent)",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ],
      "title": "Cost per Query Type",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "(sum(rate(agent_tokens_input_total[5m])) + sum(rate(agent_tokens_output_total[5m]))) / sum(rate(agent_intent_classified_total[5m]))",
          "legendFormat": "tokens/query",
          "refId": "A"
        }
      ],
      "title": "Avg Tokens per Query (input + output)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(agent_intent_classified_total[5m])) by (intent)",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ],
      "title": "Query Volume Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "(1 - (sum(rate(agent_escalation_count_total[5m])) / sum(rate(agent_intent_classified_total[5m])))) or vector(1)",
          "legendFormat": "resolved",
          "refId": "A"
        }
      ],
      "title": "Resolution Rate",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "tags": [
    "agents",
    "business"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "Business / Product",
  "uid": "business"
}