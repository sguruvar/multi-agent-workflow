{
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "jaeger"
      },
      "fieldConfig": {
        "defaults": {
          "links": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "traceID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": false,
                    "title": "View Waterfall",
                    "url": "/d/observability/observability-e28094-trace-explorer?var-traceId=${__value.raw}&from=now-30m&to=now"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "traceDuration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ns"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "nested"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "jaeger"
          },
          "limit": 30,
          "query": "{resource.service.name=\"customer-support-agent\" && name=\"customer_support.invoke\"} | select(span.session.id, span.agent.intent)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Recent Sessions",
      "type": "table"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "jaeger"
          },
          "limit": 1,
          "query": "${traceId}",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Span Waterfall",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "jaeger"
          },
          "limit": 1,
          "query": "${traceId}",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Service Map",
      "type": "nodeGraph"
    }
  ],
  "refresh": "10s",
  "tags": [
    "agents",
    "traces"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "value": ""
        },
        "label": "Trace ID",
        "name": "traceId",
        "options": [],
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "Observability \u2014 Trace Explorer",
  "uid": "observability"
}