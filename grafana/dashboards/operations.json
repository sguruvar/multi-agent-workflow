{
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(agent_cost_usd_total[5m])) / 1000000 * 3600",
          "legendFormat": "current $/hr",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "avg_over_time((sum(rate(agent_cost_usd_total[5m])) / 1000000 * 3600)[30m:])",
          "legendFormat": "avg $/hr",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Cost Spike Alert ($/hr)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "1 - (sum(rate(agent_invocation_duration_milliseconds_bucket{le=\"30000\"}[5m])) / sum(rate(agent_invocation_duration_milliseconds_count[5m])))",
          "legendFormat": "timeout %",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Agent Timeout Rate (>30s)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(increase(agent_tool_errors_total[5m]))",
          "legendFormat": "errors",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Failed Routes",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(agent_invocation_duration_milliseconds_count[5m])) by (agent_name)",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Invocation Rate by Agent",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(increase(agent_invocation_duration_milliseconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "title": "Request Duration Heatmap",
      "type": "heatmap"
    }
  ],
  "refresh": "10s",
  "tags": [
    "agents",
    "operations"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "Operations",
  "uid": "operations"
}